# Bid Collections Rails API (browser → this host). DP is called server-side by Rails, not here.
VITE_API_BASE_URL=http://127.0.0.1:3000
VITE_API_PREFIX=/api
VITE_DP_INTEGRATION=1

# Do NOT set VITE_API_BASE_URL to designerpages.com for local dev: /api/dp/* routes
# exist only on Bid Collections. Rails uses DP_API_BASE_URL / initializer to reach DP.
