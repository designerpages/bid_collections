# Local dev: point at Bid Collections Rails (bin/rails s, default port 3000).
VITE_API_BASE_URL=http://127.0.0.1:3000
VITE_API_PREFIX=/api

# Set to 1 to resolve project context via DP (Import page needs ?firm_id=&project_name=).
# Browser still talks to Rails; Rails proxies to DP with HMAC.
# VITE_DP_INTEGRATION=1

# If VITE_API_BASE_URL is unset, api.js falls back by Vite mode:
# - development: http://127.0.0.1:3000
# - staging: https://staging.designerpages.com
# - production: https://www.designerpages.com
